# Image versions are pinned so upgrades are deliberate and reviewable.
PROMETHEUS_VERSION=v3.12.0
LOKI_VERSION=3.7.2
TEMPO_VERSION=2.10.5
ALLOY_VERSION=v1.16.1
GRAFANA_VERSION=13.0.2
NODE_EXPORTER_VERSION=v1.11.1
CADVISOR_VERSION=v0.57.0

# Backend UIs bind to localhost by default. Set 0.0.0.0 only behind a firewall
# or authenticated reverse proxy.
BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
ALLOY_PORT=12345
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8080

# OTLP must be reachable by the applications that send traces.
OTLP_BIND_ADDRESS=0.0.0.0
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

PROMETHEUS_RETENTION=15d
LOKI_RETENTION=360h
TEMPO_RETENTION=168h
